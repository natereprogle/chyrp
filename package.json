{
  "name": "chyrp",
  "version": "0.1.1",
  "description": "Toasts that get your attention. Dependency-free toast notification library with stacking, swipe-to-dismiss, sounds, and promise integration.",
  "type": "module",
  "author": "Nate Reprogle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natereprogle/chyrp.git"
  },
  "bugs": {
    "url": "https://github.com/natereprogle/chyrp/issues"
  },
  "homepage": "https://natereprogle.github.io/chyrp/demo/",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsdown",
    "build:minify": "tsdown --minify",
    "build:dev": "tsdown --watch",
    "demo": "concurrently -k -n build,serve \"npm:build:dev\" \"serve -l 3000\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run build:minify"
  },
  "keywords": [
    "toast",
    "notification",
    "alert",
    "snackbar",
    "popup",
    "ui"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
